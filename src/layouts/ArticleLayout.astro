---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags?: string[];
  readingTime: number;
}

const { title, date, excerpt, tags = [], readingTime } = Astro.props;

/**
 * Format a Date as French long date: "10 avril 2026"
 */
function formatDateFr(d: Date): string {
  return d.toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<BaseLayout title={title} description={excerpt}>
  <div class="article-page">
    <div class="container container--narrow">

      <article>
        <header class="article-header">
          {tags.length > 0 && (
            <div class="article-header__tags">
              {tags.map((tag) => (
                <span class="tag tag--article">{tag}</span>
              ))}
            </div>
          )}

          <h1 class="article-header__title">{title}</h1>

          <div class="article-header__meta">
            <time datetime={date.toISOString()}>
              {formatDateFr(date)}
            </time>
            <span class="article-header__meta-sep" aria-hidden="true">&middot;</span>
            <span>{readingTime} min de lecture</span>
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>

        <footer class="article-footer">
          <a href={import.meta.env.BASE_URL} class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Retour aux articles
          </a>
        </footer>
      </article>

    </div>
  </div>
</BaseLayout>
